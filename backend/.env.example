# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
OPUS_MODEL=claude-opus-4-7
SONNET_MODEL=claude-sonnet-4-6

# Gemini — verify model ID at https://ai.google.dev/gemini-api/docs/image-generation
GEMINI_API_KEY=xxx
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Asset storage (R2 recommended; s3 also works; local for dev)
ASSET_STORE_PROVIDER=local
ASSET_STORE_BUCKET=web3growthlab-ad-machine-assets
ASSET_STORE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
ASSET_STORE_ACCESS_KEY=xxx
ASSET_STORE_SECRET_KEY=xxx
ASSET_STORE_PUBLIC_BASE_URL=https://assets.web3growthlab.com
LOCAL_ASSET_DIR=/tmp/ad-machine-assets

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/adcreative

# Buffer (per-user OAuth; service token for testing)
BUFFER_ACCESS_TOKEN=xxx

# Image generation tuning
IMAGE_GEN_BATCH_SIZE=5
IMAGE_GEN_BATCH_DELAY_S=1.0
IMAGE_GEN_TOP_VARIATIONS=3

# Job timeout
AD_MACHINE_JOB_TIMEOUT_S=600

# CORS
CORS_ORIGINS=http://localhost:5173,https://web3growthlabs.com

# Optional: path to ai-content-machine for voice/anti-slop packages
AI_CONTENT_MACHINE_PATH=/path/to/ai-content-machine/backend
VOICES_PATH=voices
